<%- include('_layout-header', { pageTitle: 'Dashboard', adminActive: 'dashboard' }) %>

<div class="admin-topbar">
  <h1 style="font-size:20px;">Dashboard</h1>
</div>

<div class="stat-grid">
  <div class="stat-card"><div class="num"><%= stats.totalJobs %></div><div class="lbl">Total jobs</div></div>
  <div class="stat-card"><div class="num"><%= stats.publishedJobs %></div><div class="lbl">Published jobs</div></div>
  <div class="stat-card"><div class="num"><%= stats.totalQuestions %></div><div class="lbl">Quiz questions</div></div>
