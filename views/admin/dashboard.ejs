</div>

<div style="display:flex; gap:12px;">
  <a href="/admin/jobs/new" class="btn-primary" style="display:inline-block;">+ Naya job add karein</a>
  <a href="/admin/quiz-questions/new" class="btn-primary" style="display:inline-block; background:#16a34a;">+ Nayi quiz question add karein</a>
