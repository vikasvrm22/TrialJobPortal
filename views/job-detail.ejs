<%- include('partials/header', { pageTitle: job.title }) %>

<div class="detail-box">
  <span class="badge badge-<%= job.status %>"><%= job.status %></span>
  <h1 style="margin-top:10px;"><%= job.title %></h1>
  <p style="color:#666; font-size:14px;"><%= job.description %></p>

  <div class="detail-grid">
    <div class="detail-item"><div class="label">Category</div><div class="value"><%= job.category %></div></div>
    <div class="detail-item"><div class="label">Total posts</div><div class="value"><%= job.posts || 'N/A' %></div></div>
    <div class="detail-item"><div class="label">Qualification</div><div class="value"><%= job.qualification || 'N/A' %></div></div>
    <div class="detail-item"><div class="label">Last date</div><div class="value"><%= job.last_date || 'N/A' %></div></div>
  </div>

  <% if (job.apply_link) { %>
    <a href="<%= job.apply_link %>" target="_blank" rel="noopener" class="apply-btn">Official website par apply karein →</a>
  <% } %>

  <p style="margin-top:20px; font-size:12px; color:#999;">
    Apply karne se pehle official notification zaroor padhein. <a href="/disclaimer" style="text-decoration:underline;">Disclaimer padhein</a>.
  </p>
</div>

<%- include('partials/footer') %>
